<% layout('layout') %>

<div class="detail-card">
  <h1><%= resource.title %></h1>

  <!-- Category & Difficulty Badges -->
  <div class="detail-meta">
    <span class="badge badge-<%= resource.category.toLowerCase() %>">
      <%= resource.category %>
    </span>
    <span class="badge badge-<%= resource.difficulty.toLowerCase() %>">
      <%= resource.difficulty %>
    </span>
    <span class="rating">
      <% for (let i = 1; i <= 5; i++) { %>
        <%= i <= resource.rating ? '★' : '☆' %>
      <% } %>
      (<%= resource.rating %>/5)
    </span>
  </div>

  <!-- Description -->
  <div class="detail-field">
    <strong>Description</strong>
    <p class="detail-description"><%= resource.description %></p>
  </div>

  <!-- Link -->
  <div class="detail-field">
    <strong>Resource Link</strong>
    <p><a href="<%= resource.link %>" target="_blank" rel="noopener noreferrer"><%= resource.link %></a></p>
  </div>

  <!-- Tags -->
  <% if (resource.tags && resource.tags.length > 0) { %>
    <div class="detail-field">
      <strong>Tags</strong>
      <div class="detail-tags">
        <% resource.tags.forEach(tag => { %>
          <span class="tag"><%= tag %></span>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Created Date -->
  <div class="detail-field">
    <strong>Created</strong>
    <p><%= resource.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
  </div>

  <% if (resource.updatedAt && resource.updatedAt.getTime() !== resource.createdAt.getTime()) { %>
    <div class="detail-field">
      <strong>Last Updated</strong>
      <p><%= resource.updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
    </div>
  <% } %>

  <!-- Actions -->
  <div class="detail-actions">
    <a href="/resources/<%= resource._id %>/edit" class="btn btn-primary">Edit</a>
    <form action="/resources/<%= resource._id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this resource?');">
      <button type="submit" class="btn btn-danger">Delete</button>
    </form>
    <a href="/resources" class="btn btn-secondary">Back to List</a>
  </div>
</div>
