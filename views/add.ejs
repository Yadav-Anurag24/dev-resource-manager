<% layout('layout') %>

<div class="form-card">
  <h1 style="margin-bottom: 24px;">Add New Resource</h1>

  <!-- Error Messages -->
  <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="alert alert-danger">
      <strong>Please fix the following errors:</strong>
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form action="/resources" method="POST">
    <div class="form-group">
      <label for="title">Title *</label>
      <input
        type="text"
        id="title"
        name="title"
        placeholder="e.g., Striver's DSA Sheet"
        value="<%= typeof formData !== 'undefined' && formData.title ? formData.title : '' %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description *</label>
      <textarea
        id="description"
        name="description"
        placeholder="Describe this learning resource..."
        required
      ><%= typeof formData !== 'undefined' && formData.description ? formData.description : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="category">Category *</label>
      <select id="category" name="category" required>
        <option value="">Select Category</option>
        <option value="DSA" <%= typeof formData !== 'undefined' && formData.category === 'DSA' ? 'selected' : '' %>>DSA</option>
        <option value="Backend" <%= typeof formData !== 'undefined' && formData.category === 'Backend' ? 'selected' : '' %>>Backend</option>
        <option value="DevOps" <%= typeof formData !== 'undefined' && formData.category === 'DevOps' ? 'selected' : '' %>>DevOps</option>
        <option value="AI" <%= typeof formData !== 'undefined' && formData.category === 'AI' ? 'selected' : '' %>>AI</option>
      </select>
    </div>

    <div class="form-group">
      <label for="difficulty">Difficulty *</label>
      <select id="difficulty" name="difficulty" required>
        <option value="">Select Difficulty</option>
        <option value="Beginner" <%= typeof formData !== 'undefined' && formData.difficulty === 'Beginner' ? 'selected' : '' %>>Beginner</option>
        <option value="Intermediate" <%= typeof formData !== 'undefined' && formData.difficulty === 'Intermediate' ? 'selected' : '' %>>Intermediate</option>
        <option value="Advanced" <%= typeof formData !== 'undefined' && formData.difficulty === 'Advanced' ? 'selected' : '' %>>Advanced</option>
      </select>
    </div>

    <div class="form-group">
      <label for="link">Resource Link *</label>
      <input
        type="url"
        id="link"
        name="link"
        placeholder="https://example.com/resource"
        value="<%= typeof formData !== 'undefined' && formData.link ? formData.link : '' %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="tags">Tags</label>
      <input
        type="text"
        id="tags"
        name="tags"
        placeholder="e.g., arrays, graphs, sorting (comma-separated)"
        value="<%= typeof formData !== 'undefined' && formData.tags ? formData.tags : '' %>"
      />
      <small>Separate tags with commas</small>
    </div>

    <div class="form-group">
      <label for="rating">Rating (0–5)</label>
      <select id="rating" name="rating">
        <option value="0" <%= typeof formData !== 'undefined' && formData.rating == '0' ? 'selected' : '' %>>0 - Not Rated</option>
        <option value="1" <%= typeof formData !== 'undefined' && formData.rating == '1' ? 'selected' : '' %>>1 - Poor</option>
        <option value="2" <%= typeof formData !== 'undefined' && formData.rating == '2' ? 'selected' : '' %>>2 - Fair</option>
        <option value="3" <%= typeof formData !== 'undefined' && formData.rating == '3' ? 'selected' : '' %>>3 - Good</option>
        <option value="4" <%= typeof formData !== 'undefined' && formData.rating == '4' ? 'selected' : '' %>>4 - Very Good</option>
        <option value="5" <%= typeof formData !== 'undefined' && formData.rating == '5' ? 'selected' : '' %>>5 - Excellent</option>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create Resource</button>
      <a href="/resources" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
